{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.8",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "My App, Inc. (SVV Agent v1.0.8)",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Statens Vegvesen Agent${{APP_NAME_SUFFIX}}",
        "full": "Full name for Statens Vegvesen Agent"
    },
    "description": {
        "short": "Statens Vegvesen Agent v1.0.8",
        "full": "Full description for Statens Vegvesen Agent"
    },
    "accentColor": "#FFFFFF",
    "copilotAgents": {
        "declarativeAgents": [            
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "akfell-datautlevering.atlas.vegvesen.no",
        "www.carimagery.com",
        "www.regcheck.org.uk"
    ]
}
